<Window x:Class="ClaudeGui.ChatHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="聊天记录速览"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a2e"
        TextElement.Foreground="#e0e0e0">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ToolBtn">
            <Setter Property="Background" Value="#233554"/>
            <Setter Property="Foreground" Value="#8892b0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#233554"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#64ffda"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ToggleButton" x:Key="FilterToggle">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#8892b0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#233554"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#64ffda"/>
                    <Setter Property="Foreground" Value="#1a1a2e"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Border Grid.Row="0" Background="#16213e" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="TxtTitle" Text="📋 聊天记录"
                           FontSize="14" FontWeight="Bold" Foreground="#64ffda"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBox Grid.Column="1" x:Name="SearchBox"
                         Background="#0c0c0c" Foreground="#cccccc"
                         BorderBrush="#444444" BorderThickness="1"
                         Padding="8,4" CaretBrush="#64ffda"
                         FontSize="12" VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"
                         ToolTip="搜索历史（Enter 下一个，Shift+Enter 上一个）"/>

                <ToggleButton Grid.Column="2" x:Name="BtnFilterUser"
                              Style="{StaticResource FilterToggle}"
                              Content="👤 只看用户" Margin="8,0,0,0"
                              Checked="FilterUser_Checked"
                              Unchecked="FilterUser_Unchecked"/>

                <TextBlock Grid.Column="3" x:Name="TxtStats"
                           Text="" Foreground="#8892b0" FontSize="11"
                           VerticalAlignment="Center" Margin="16,0,8,0"/>

                <Button Grid.Column="4" Content="✕" Width="28" Height="28"
                        Background="Transparent" Foreground="#64ffda"
                        FontSize="14" BorderThickness="1" BorderBrush="#64ffda"
                        Cursor="Hand" Click="CloseBtn_Click"/>
            </Grid>
        </Border>

        <!-- 内容区 -->
        <RichTextBox x:Name="OutputBox" Grid.Row="1"
                     Background="#0c0c0c" Foreground="#cccccc"
                     FontFamily="Consolas" FontSize="13"
                     IsReadOnly="True" BorderThickness="0"
                     VerticalScrollBarVisibility="Auto"
                     Padding="12,8">
            <RichTextBox.Resources>
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0,0,0,0"/>
                    <Setter Property="LineHeight" Value="18"/>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#16213e" Padding="12,4">
            <TextBlock x:Name="TxtStatus" Text="加载中..."
                       Foreground="#666" FontSize="11"/>
        </Border>

        <!-- 加载中覆盖层 -->
        <Border x:Name="LoadingOverlay" Grid.Row="1" Grid.RowSpan="2"
                Background="#800c0c0c" Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="⏳ 加载中..." Foreground="#64ffda" FontSize="14"
                       Padding="20,10"/>
        </Border>
    </Grid>
</Window>
