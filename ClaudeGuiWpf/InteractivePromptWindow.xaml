<Window x:Class="ClaudeGui.InteractivePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 提问" Width="520" Height="420"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Topmost="True" ShowInTaskbar="True"
        Background="#16213e"
        Loaded="Window_Loaded" KeyDown="Window_KeyDown">
    <Border Background="#16213e" BorderBrush="#233554" BorderThickness="1"
            CornerRadius="8" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题：项目名 + 问题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock x:Name="TxtProject" FontSize="11" Foreground="#8892b0"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtQuestion" FontSize="15" FontWeight="Bold"
                           Foreground="#64ffda" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 多选提示 -->
            <TextBlock x:Name="TxtMultiHint" Grid.Row="1" FontSize="11"
                       Foreground="#8892b0" Margin="0,0,0,8" Visibility="Collapsed"
                       Text="（可多选，点击选项切换选中状态）"/>

            <!-- 选项列表 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,14">
                <StackPanel x:Name="OptionsPanel"/>
            </ScrollViewer>

            <!-- 按钮行 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="跳过" Width="80" Height="34"
                        Background="#233554" Foreground="#8892b0"
                        FontSize="13" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0"
                        Click="Skip_Click"/>
                <Button x:Name="BtnConfirm" Content="确定" Width="100" Height="34"
                        Background="#64ffda" Foreground="#1a1a2e"
                        FontWeight="Bold" FontSize="13" BorderThickness="0"
                        Cursor="Hand" Click="Confirm_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
