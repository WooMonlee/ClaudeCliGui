<Window x:Class="ClaudeGui.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建项目" Width="450" Height="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#16213e">

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8892b0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#64ffda"/>
        <SolidColorBrush x:Key="BgBrush" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#233554"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="60"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="新建项目" FontSize="18" FontWeight="Bold" Foreground="#64ffda" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="项目名称" FontSize="12" Foreground="#8892b0" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="TxtName" Background="#1a1a2e" Foreground="#e0e0e0"
                 BorderBrush="#233554" Padding="8" CaretBrush="#64ffda"
                 TextChanged="OnTextChanged" KeyDown="OnKeyDown"/>

        <TextBlock Grid.Row="3" Text="父目录" FontSize="12" Foreground="#8892b0" Margin="0,10,0,4"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="TxtParentDir" Background="#1a1a2e" Foreground="#e0e0e0"
                     BorderBrush="#233554" Padding="8" CaretBrush="#64ffda"
                     TextChanged="OnTextChanged" KeyDown="OnKeyDown"/>
            <Button Grid.Column="1" Content="浏览..." Margin="8,0,0,0" Width="60"
                    Click="Browse_Click" Style="{StaticResource {x:Type Button}}"
                    Background="#0f3460" Foreground="#64ffda" BorderBrush="#233554"/>
        </Grid>

        <TextBox Grid.Row="5" x:Name="TxtPreview" FontSize="11" Foreground="#8892b0" Margin="0,8,0,0"
                 Background="Transparent" BorderThickness="0" IsReadOnly="True"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 MinHeight="36" VerticalAlignment="Stretch"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,36,0,0">
            <Button Content="取消" Width="80" Click="Cancel_Click"
                    Background="#0f3460" Foreground="#e0e0e0" BorderBrush="#233554"/>
            <Button Content="创建" Width="80" Margin="8,0,0,0" Click="CreateBtn_Click"
                    Background="#64ffda" Foreground="#1a1a2e" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
