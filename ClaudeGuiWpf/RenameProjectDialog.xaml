<Window x:Class="ClaudeGui.RenameProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名项目" Width="380" Height="160"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="#16213e">
    <Border Background="#16213e" BorderBrush="#233554" BorderThickness="1"
            CornerRadius="8" Padding="20">
        <StackPanel>
            <TextBlock Text="重命名项目" Foreground="#64ffda" FontSize="16"
                       FontWeight="Bold" Margin="0,0,0,14"/>
            <TextBox x:Name="NameBox" Background="#0c0c0c" Foreground="#e0e0e0"
                     CaretBrush="#64ffda" FontSize="14"
                     Padding="8,6" BorderBrush="#233554" Margin="0,0,0,14"
                     KeyDown="NameBox_KeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="取消" Width="70" Height="30"
                        Background="#233554" Foreground="#8892b0"
                        FontSize="12" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,8,0"
                        Click="CancelBtn_Click"/>
                <Button x:Name="OkBtn" Content="确定" Width="70" Height="30"
                        Background="#64ffda" Foreground="#1a1a2e"
                        FontWeight="Bold" FontSize="12" BorderThickness="0"
                        Cursor="Hand" Click="OkBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
