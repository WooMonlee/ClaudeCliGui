<UserControl x:Class="ClaudeGui.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0c0c0c"
             AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="OutputRow" Height="*"/>
            <RowDefinition x:Name="ThinkSplitterRow" Height="Auto"/>
            <RowDefinition x:Name="ThinkRow" Height="0"/>
            <RowDefinition Height="6"/>     <!-- 拖拽条 -->
            <RowDefinition x:Name="InputRow" Height="100" MinHeight="40"/>
        </Grid.RowDefinitions>

        <!-- ===== 正式回复输出区域 ===== -->
        <RichTextBox x:Name="OutputBox" Grid.Row="0"
                     Background="#0c0c0c" Foreground="#cccccc"
                     FontFamily="Consolas" FontSize="13"
                     IsReadOnly="True" BorderThickness="0"
                     VerticalScrollBarVisibility="Auto"
                     Padding="12,8">
            <RichTextBox.Resources>
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0,0,0,0"/>
                    <Setter Property="LineHeight" Value="18"/>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <!-- 加载提示 -->
        <TextBlock x:Name="TxtPlaceholder" Grid.Row="0"
                   Text="选择左侧项目，在此启动 Claude 终端"
                   Foreground="#8892b0" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Visible"/>

        <!-- 输出/思考分隔条（思考窗显示时才可见） -->
        <GridSplitter x:Name="ThinkSplitter" Grid.Row="1"
                      Height="5" HorizontalAlignment="Stretch"
                      Background="#333333" ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows" Cursor="SizeNS"
                      Visibility="Collapsed"/>

        <!-- ===== 思考面板：思考/tool_use/system 原始输出 ===== -->
        <Border x:Name="ThinkingPanel" Grid.Row="2"
                Background="#0a0a14" BorderBrush="#233554" BorderThickness="2"
                Visibility="Collapsed" MinHeight="40">
            <Border.Resources>
                <Storyboard x:Key="BreathingGlow" RepeatBehavior="Forever">
                    <ColorAnimation Storyboard.TargetName="ThinkingPanel"
                                    Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                    From="#334466" To="#ffffff" Duration="0:0:2.5"
                                    AutoReverse="True"/>
                </Storyboard>
            </Border.Resources>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ThinkingBox" Grid.Column="0"
                         Background="#0a0a14" Foreground="#8892b0"
                         FontFamily="Consolas" FontSize="13"
                         IsReadOnly="True" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Padding="12,6"/>
            </Grid>
        </Border>

        <!-- 拖拽条 -->
        <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch"
                      Background="#333333" ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows" Cursor="SizeNS"/>

        <!-- 输入区域 -->
        <Border Grid.Row="4" Background="#1a1a1a" BorderBrush="#333333" BorderThickness="0,1,0,0">
            <Grid Margin="10,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="InputBox" Grid.Row="0"
                         Background="#0c0c0c" Foreground="#cccccc"
                         FontFamily="Consolas" FontSize="13"
                         BorderBrush="#444444" BorderThickness="1"
                         Padding="8,6" CaretBrush="#64ffda"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         IsEnabled="True"
                         KeyDown="InputBox_KeyDown"
                         TextChanged="InputBox_TextChanged"/>

                <!-- 按钮行 -->
                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="24,0,0,0">
                        <ComboBox x:Name="CmbSkills" Width="130" Height="26" FontSize="11"
                                  Background="#0f3460" Foreground="#80b3ff" BorderBrush="#233554"
                                  SelectionChanged="Skill_Selected" IsEnabled="False" Visibility="Collapsed"/>
                        <ComboBox x:Name="CmbTips" Width="130" Height="26" FontSize="11" Margin="24,0,0,0"
                                  Background="#0f3460" Foreground="#80b3ff" BorderBrush="#233554"
                                  SelectionChanged="Tip_Selected" IsEnabled="False" Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtStats" Text="" Foreground="#64ffda" FontSize="10"
                                   VerticalAlignment="Center" Margin="40,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                        <Button x:Name="BtnThinking" Content="💭" Width="36" Height="30"
                                Background="#233554" Foreground="#8892b0"
                                FontWeight="Bold" BorderThickness="0"
                                Visibility="Collapsed" Click="ShowThinkingOverlay"
                                ToolTip="查看本次思考过程"/>
                        <Button x:Name="BtnSend" Content="发送" Width="130" Height="30"
                                Background="#64ffda" Foreground="#1a1a2e"
                                FontWeight="Bold" BorderThickness="0"
                                IsEnabled="False" Visibility="Collapsed" Click="Send_Click"/>
                        <TextBlock Text="Ctrl+Enter" Foreground="#666666" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,8,0"/>
                        <Button x:Name="BtnStop" Content="停止" Width="60" Height="30"
                                Background="#ff6b6b" Foreground="white"
                                FontWeight="Bold" BorderThickness="0"
                                Visibility="Collapsed" Click="Stop_Click"/>
                        <Button x:Name="BtnNotebook" Content="📋" Width="30" Height="30" Margin="16,0,0,0"
                                Background="#233554" Foreground="#8892b0"
                                FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                Click="ToggleNotebook_Click"
                                ToolTip="打开/关闭备忘记事本"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ===== 思考全屏覆盖层 ===== -->
        <Border x:Name="ThinkingOverlay" Grid.RowSpan="5"
                Background="#CC0c0c14" Visibility="Collapsed"
                MouseLeftButtonDown="HideThinkingOverlay">
            <Border Width="720" MaxHeight="700"
                    Background="#0e0e1a" BorderBrush="#233554" BorderThickness="1"
                    CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                    MouseLeftButtonDown="OverlayPanel_PreviewMouseDown">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="💭 思考过程" FontSize="14" FontWeight="Bold"
                                   Foreground="#64ffda" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BtnCloseOverlay" Content="✕" Width="32" Height="32"
                                    Background="Transparent" Foreground="#64ffda" FontSize="14"
                                    BorderThickness="1" BorderBrush="#64ffda"
                                    Cursor="Hand" Click="CloseOverlay_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBox x:Name="ThinkingFullBox" Grid.Row="1"
                             Background="#0e0e1a" Foreground="#8892b0"
                             FontFamily="Consolas" FontSize="13"
                             IsReadOnly="True" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
