<UserControl x:Class="ClaudeGui.FileBrowserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1a1a2e">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 标题栏 -->
        <TextBlock x:Name="TitleText" Grid.Row="0"
                   Foreground="#64ffda" FontSize="12" FontWeight="Bold"
                   Padding="12,8" TextTrimming="CharacterEllipsis"/>
        <!-- 树形文件列表 -->
        <ScrollViewer x:Name="FileBrowserScroll" Grid.Row="1"
                      Background="#16213e" VerticalScrollBarVisibility="Auto"
                      BorderThickness="0">
            <StackPanel x:Name="FileBrowserPanelInner" Margin="0,0,0,8"/>
        </ScrollViewer>
    </Grid>
</UserControl>
